# 🔐 School Management System - Environment Template
# Copy this to .env (local) or your Render Environment dashboard (production)

# [CORE SETTINGS]
DEBUG=False
SECRET_KEY=generate-a-long-random-secret-key-here-for-production
ALLOWED_HOSTS=localhost,127.0.0.1,management-system-bk6v.onrender.com

# [DATABASE]
# Render automatically provides DATABASE_URL
DATABASE_URL=postgres://user:password@hostname:port/dbname

# [CACHE]
# Optional: Set this if you have a Redis instance
REDIS_URL=

# [EMAIL]
# Default is console backend. Change for production (e.g., SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@edums.edu